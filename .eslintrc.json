{
  "extends": ["next/core-web-vitals", "prettier"],
  "ignorePatterns": ["docs/**"],
  "rules": {
    "padding-line-between-statements": [
      "error",
      { "blankLine": "always", "prev": "*", "next": "return" },
      { "blankLine": "always", "prev": "*", "next": "if" },
      { "blankLine": "always", "prev": "if", "next": "*" },
      { "blankLine": "always", "prev": "*", "next": "try" }
    ]
  }
}
