# ──────────────────────────────────────────────────────────────
# Internal JWT (stateless session in an httpOnly cookie)
# Generate a strong secret: openssl rand -base64 48
# ──────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_TTL_SECONDS=28800            # 8h

# ──────────────────────────────────────────────────────────────
# Brisanet SSO (viewer login). For local dev point SSO_BASE_URL at the stub:
#   SSO_BASE_URL=http://localhost:4555
# ──────────────────────────────────────────────────────────────
SSO_BASE_URL=https://revan.brisanet.net.br/sso/v1
SSO_PICTURE_BASE_URL=https://novorevan.brisanet.net.br/assets/img/users
NEXT_PUBLIC_SSO_PICTURE_BASE_URL=https://novorevan.brisanet.net.br/assets/img/users

# ──────────────────────────────────────────────────────────────
# Data source: mock (dev) | databricks (prod)
# ──────────────────────────────────────────────────────────────
DATA_SOURCE=mock

# Databricks (when DATA_SOURCE=databricks). Queries run under ONE service
# principal (OAuth M2M, preferred) — see ADR 0003.
DATABRICKS_HOST=
DATABRICKS_HTTP_PATH=
DATABRICKS_SP_CLIENT_ID=
DATABRICKS_SP_CLIENT_SECRET=
# OR a personal access token:
DATABRICKS_TOKEN=
# Optional overrides for the cities source location:
DATABRICKS_CITIES_CATALOG=gdb_brisanet_comunidade_dev
DATABRICKS_CITIES_SCHEMA=projeto_brisa_performance

# ──────────────────────────────────────────────────────────────
# Cache / freshness (see ADR 0002). Source refreshes hourly.
# ──────────────────────────────────────────────────────────────
DATA_CACHE_TTL_SECONDS=3600      # safety ceiling; floor 60
DATA_AUTO_REFRESH=false          # on = poll watermark and refresh when source advances
DATA_WATERMARK_POLL_SECONDS=60
